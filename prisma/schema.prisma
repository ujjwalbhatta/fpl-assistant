generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerStatus {
  AVAILABLE
  DOUBTFUL
  INJURED
  SUSPENDED
  UNAVAILABLE
}

enum GameweekStatusType {
  BLANK
  SINGLE
  DOUBLE
}

model Team {
  id        Int    @id
  name      String
  shortName String

  players          Player[]
  homeFixtures     Fixture[]            @relation("HomeTeam")
  awayFixtures     Fixture[]            @relation("AwayTeam")
  gameweekStatuses TeamGameweekStatus[]
}

model Player {
  id      Int    @id
  webName String

  position Int  // 1=GK 2=DEF 3=MID 4=FWD
  teamId   Int
  team     Team @relation(fields: [teamId], references: [id])

  nowCost          Int   @default(0)
  form             Float @default(0)
  totalPoints      Int   @default(0)
  pointsPerGame    Float @default(0)
  selectedByPercent Float @default(0)
  transfersInEvent Int   @default(0)

  status                   PlayerStatus @default(AVAILABLE)
  chanceOfPlayingNextRound Int?
  news                     String?

  goalsScored  Int   @default(0)
  assists      Int   @default(0)
  cleanSheets  Int   @default(0)

  ictIndex        Float @default(0)
  expectedGIPer90 Float @default(0)

  penaltiesOrder Int?

  valueIndex   Float @default(0)
  fixtureScore Float @default(0)

  priceChanges  PriceHistory[]
  gameweekStats PlayerGameweekStat[]

  @@index([position])
  @@index([status])
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
  oldCost   Int
  newCost   Int
  changedAt DateTime @default(now())

  @@index([playerId])
}

model PlayerGameweekStat {
  id       Int    @id @default(autoincrement())
  playerId Int
  player   Player @relation(fields: [playerId], references: [id])
  gameweek Int

  minutes     Int @default(0)
  totalPoints Int @default(0)
  cbit        Int @default(0)
  cbirt       Int @default(0)
  dcPoints    Int @default(0)

  @@unique([playerId, gameweek])
  @@index([gameweek])
  @@index([playerId])
}

model Fixture {
  id       Int  @id
  gameweek Int

  homeTeamId Int
  awayTeamId Int
  homeTeam   Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeTeamDifficulty Int
  awayTeamDifficulty Int
  finished           Boolean @default(false)

  @@index([gameweek])
  @@index([homeTeamId, gameweek])
  @@index([awayTeamId, gameweek])
}

model Gameweek {
  id        Int     @id
  name      String
  isCurrent Boolean @default(false)
  isNext    Boolean @default(false)
  finished  Boolean @default(false)

  @@index([isCurrent])
}

model TeamGameweekStatus {
  id           Int                @id @default(autoincrement())
  teamId       Int
  team         Team               @relation(fields: [teamId], references: [id])
  gameweek     Int
  status       GameweekStatusType @default(SINGLE)
  fixtureCount Int                @default(1)

  @@unique([teamId, gameweek])
  @@index([gameweek])
}

model PlayerTrend {
  id       Int @id @default(autoincrement())
  playerId Int
  gameweek Int

  rollingAvgPts  Float
  formScore      Float
  valueIndex     Float
  fixtureScore   Float
  ownershipPct   Float
  priceRiseCount Int   @default(0)
  dcAvgPerGame   Float @default(0)
  dcHitRatePct   Float @default(0)
  isDgwNext      Boolean @default(false)
  isBgwNext      Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([playerId, gameweek])
  @@index([gameweek])
  @@index([valueIndex])
}
